generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Leaderboard {
  id         String   @id @default(cuid())
  playerName String
  score      Int
  wins       Int
  battles    Int
  createdAt  DateTime @default(now())

  @@index([score(sort: Desc)])
}
